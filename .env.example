# ProLine Partner API credentials
# Both are required on every API call.
#
# PARTNER_KEY is issued to approved ProLine partners (one per developer/agent).
# See docs/partner-key-request.md for how to request one.
#
# COMPANY_KEY is found in your ProLine account Settings → Integrations.
# It authorizes access to a specific company's data.

PROLINE_PARTNER_KEY=
PROLINE_COMPANY_KEY=
